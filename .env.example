# --- LLM transport (Ollamus proxy, native Ollama /api/chat) ---
# Base URL of the Ollamus proxy (no trailing /api/chat, just the host root).
LLM_BASE_URL=https://ollamus.example.us.es
# Bearer token for the Ollamus proxy.
LLM_API_KEY=changeme
# Default model id used when --model is not passed on the CLI.
LLM_MODEL=llama3.1:8b

# --- phmlc bridge ---
# Path to phmlc's `src` folder. Relative paths are resolved from LUMES/.
PHMLC_SRC=../phmlc/src
